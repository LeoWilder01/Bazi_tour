.container {
  padding: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}
.picker {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}
button {
  margin-bottom: 24rpx;
}
.error {
  color: #e64340;
  margin-bottom: 24rpx;
}
.subtitle {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.result {
  background: #f0f9eb;
  padding: 24rpx;
  border-radius: 8rpx;
  color: #333;
}